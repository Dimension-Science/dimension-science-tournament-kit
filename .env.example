APP_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tournament?sslmode=disable

SESSION_SECRET=replace_with_a_long_random_secret
AUTH_SESSION_HOURS=12
AUTH_COOKIE_NAME=tournament_session
AUTH_COOKIE_SECURE=false

MOD_API_KEY=replace_with_a_long_random_api_key
MOD_SIGNING_SECRET=replace_with_a_long_random_signing_secret
MOD_TOKEN_ENCRYPTION_SECRET=replace_with_a_long_random_token_encryption_secret
MOD_MAX_SKEW_SEC=120

ALLOW_DEV_MOCK_AUTH=true
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/api/auth/twitch/callback
TWITCH_FORCE_VERIFY=false
ENABLE_TWITCH_STREAM_CHECKS=true
STREAM_STATUS_CACHE_SEC=60
ALLOWED_ORIGINS=http://localhost:3000

TOURNAMENT_TITLE=Example Speedrun Tournament
SITE_SHORT_NAME=EST
ORGANIZER_NAME=Dimension Science
ORGANIZER_URL=
SUPPORT_URL=
TELEGRAM_URL=
DISCORD_URL=
TWITCH_URL=
GAME_NAME=Minecraft Java Edition
GAME_VERSION=1.21.11
PRIZE_TEXT=

CERTIFICATE_TEMPLATE_DIR=assets/certificates
CERTIFICATE_PREFIX=CERT-2026
BADGE_ASSET_DIR=internal/web/static
ENABLE_ACHIEVEMENTS=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=0
TELEGRAM_NEWS_CHAT=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_NEWS_CHANNEL_ID=
DISCORD_MOD_UPDATES_CHANNEL_ID=
DISCORD_SUPPORT_CHANNEL_ID=
DISCORD_APPLICATION_LOG_CHANNEL_ID=
DISCORD_MODERATOR_ROLE_ID=
# Role granted after a Chaos application is approved. The old variable remains a fallback.
DISCORD_CHAOS_PLAYER_ROLE_ID=

# Optional synchronization with the Dimension Science website admin panel.
DIMENSION_SITE_BASE_URL=http://app:3000
DIMENSION_SITE_INTERNAL_TOKEN=
DIMENSION_SITE_CAMPAIGN_SLUG=chaos
DISCORD_RUNNER_ROLE_ID=

UPLOAD_DIR=data/uploads
MAX_AVATAR_BYTES=2097152
